---
import '../styles/global.css';
interface Props { title?: string; }
const { title = 'Fondos Familia — Guía de Inversión Familiar' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Guía de inversión familiar con 15 fondos seleccionados, calculadora de cartera y análisis completo." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="font-sans bg-slate-100 text-slate-700 antialiased">
    <slot />
  </body>
</html>
